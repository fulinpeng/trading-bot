{
    "tabWidth": 4,
    "useTabs": false,
    "semi": true,
    "singleQuote": false,
    "trailingComma": "es5",
    "bracketSpacing": false,
    "arrowParens": "always",
    "endOfLine": "auto",
    "printWidth": 100,
    "insertSpaceBeforeAndAfterBinaryOperators": true,
    "objectSpacing": false
}