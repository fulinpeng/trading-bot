<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}回测</title>
    <script src="https://cdn.jsdelivr.net/npm/echarts/dist/echarts.min.js"></script>
    <style>
        #chart {
            width: 100%;
            height: 600px;
        }

        #chart2 {
            margin-top: 50px;
            width: 100%;
            height: 600px;
        }
    </style>
</head>

<body>
    <div id="chart"></div>
    <div id="chart2"></div>
    <script>
		const chart=echarts.init(document.getElementById('chart'));
		const chart2=echarts.init(document.getElementById('chart2'));

		const upColor="#98f0b0";
		const upBorderColor="#98f0b0";
		const downColor="#f19f9f";
		const downBorderColor="#f19f9f";

		const symbol="{{symbol}}"
		const timeLevel="{{timeLevel}}"
		const kLineData={{kLineData}}
		const option={{option}}
		option.tooltip.valueFormatter=eval(option.tooltip.valueFormatter)
		const openHistory={{openHistory}}
		const closeHistory={{closeHistory}}
		const openPriceHistory={{openPriceHistory}}
		const closePriceHistory={{closePriceHistory}}
		const trendHistory={{trendHistory}}
		const curTestMoneyHistory={{curTestMoneyHistory}}

        // Each item: open，close，lowest，highest
        function splitData(rawData) {
            const categoryData = [];
            const values = [];
            for (var i = 0; i < rawData.length; i++) {
                categoryData.push(rawData[i].splice(0, 1)[0]);
                values.push(rawData[i]);
            }
            return {
                categoryData: categoryData,
                values: values,
            };
        }
        function calculateMA(dayCount) {
            var result = [];
            for (var i = 0, len = data0.values.length; i < len; i++) {
                if (i < dayCount) {
                    result.push("-");
                    continue;
                }
                var sum = 0;
                for (var j = 0; j < dayCount; j++) {
                    sum += +data0.values[i - j][2];
                }
                result.push(sum / dayCount);
            }
            return result;
        }

        function calculateEMA(dayCount, kLineData=data0.values) {
            if (!Array.isArray(kLineData) || kLineData.length === 0) {
                throw new Error("Invalid K-line data");
            }

            let result = [];
            let alpha = 2 / (dayCount + 1); // 计算平滑因子
            let emaPrev = null; // 记录上一根K线的EMA

            for (let i = 0; i < kLineData.length; i++) {
                let closePrice = +kLineData[i][2]; // 取 close 价格

                if (i < dayCount - 1) {
                    result.push(null); // 数据不足，返回 null
                } else if (i === dayCount - 1) {
                    // 初始EMA设为前 `dayCount` 天的SMA（简单移动平均）
                    let sum = 0;
                    for (let j = 0; j < dayCount; j++) {
                        sum += +kLineData[j][2]; // 取 close 价格
                    }
                    emaPrev = sum / dayCount;
                    result.push(emaPrev);
                } else {
                    // 正常计算 EMA
                    emaPrev = alpha * closePrice + (1 - alpha) * emaPrev;
                    result.push(emaPrev);
                }
            }

            return result;
        }


        // 计算标准差 (Standard Deviation)
        function stdev(values, length) {
            return values.map((val, idx, arr) => {
                // 如果当前索引小于长度，返回 null，因为还无法计算标准差
                if (idx < length - 1) return null;
                // 计算均值
                const slice = arr.slice(idx - length + 1, idx + 1);
                const mean = slice.reduce((a, b) => a + b, 0) / length;
                // 计算方差
                const variance = slice.reduce((a, b) => a + (b - mean) ** 2, 0) / length;
                // 返回标准差
                return Math.sqrt(variance);
            });
        }

        let data0 = splitData(kLineData.map(v => [v.openTime, v.open, v.close, v.low, v.high, v.closeTime]));

        console.log("🚀 ~ data0.values:", data0.values.length);

        const length = 30// 10;
        const B2mult = 2// 1.5;

        const B2basis = calculateMA(length);

        const closePrices = kLineData.map((v) => v.close);
        const B2dev = stdev(closePrices, length).map((val) => val * B2mult); // 上下轨为均值 ± 2倍标准差
        const B2upper = B2basis.map((val, idx) => val + B2dev[idx]); // 上轨
        const B2lower = B2basis.map((val, idx) => val - B2dev[idx]); // 下轨

        // console.log("🚀 ~ B2basis B2dev B2upper B2lower:", B2basis, B2dev, B2upper, B2lower)

        const markArea = openHistory.map((t, i) => {
            if (i === 1) {
                let value = trendHistory[i] === 'up' ? (closePriceHistory[i] - openPriceHistory[i]).toFixed(8) : (openPriceHistory[i] - closePriceHistory[i]).toFixed(8);
            }
            return [
                {
                    coord: [t, openPriceHistory[i]],
                    itemStyle: {
                        color: trendHistory[i] === 'up' ? 'green' : "red",
                        opacity: 0.8,
                    },
                },
                {
                    coord: [closeHistory[i], closePriceHistory[i]],
                },
            ];
        });

        const markPointData = openHistory.map((t, i) => {
            let value = trendHistory[i] === 'up' ? (closePriceHistory[i] - openPriceHistory[i]).toFixed(8) : (openPriceHistory[i] - closePriceHistory[i]).toFixed(8);
            let protectByOrderPrice = closePriceHistory[i] - openPriceHistory[i] === 0; // 保本损
            return {
                name: "Mark",
                coord: [t, openPriceHistory[i]],
                value: curTestMoneyHistory[i],
                itemStyle: {
                    color: protectByOrderPrice ? "blue" : (trendHistory[i] === 'up' ? 'greenyellow' : "orangered"),
                },
                symbol: value > 0 ? 'pin' : 'triangle',
                symbolRotate: value > 0 ? 90 : -90,
                symbolOffset: value > 0 ? [0, 0] : ['-50%', 0],
            };
        });
        const markLineData = openHistory.map((t, i) => {
            let protectByOrderPrice = closePriceHistory[i] - openPriceHistory[i] === 0; // 保本损
            return protectByOrderPrice ? [
                {
                    coord: [t, openPriceHistory[i]],
                    itemStyle: {
                        color: "blue",
                    },
                },
                {
                    coord: [closeHistory[i], closePriceHistory[i]],
                    symbol: 'none' // circle
                },
            ] : null;
        }).filter((t) => {
            return !!t;
        });
        var optionK = {
            title: {
                text: `${symbol}${timeLevel}`,
                left: 0,
            },
            tooltip: {
                trigger: "axis",
                axisPointer: {
                    type: "cross",
                },
            },
            legend: {
                // data: [timeLevel, "UP", "MA20", "DN", "EMASHORT", "EMALONG"],
                data: [timeLevel, "SMA", "EMA"],
            },
            grid: {
                left: "10%",
                right: "10%",
                bottom: "15%",
            },
            xAxis: {
                type: "category",
                data: data0.categoryData,
                boundaryGap: false,
                axisLine: { onZero: false },
                splitLine: { show: false },
                min: "dataMin",
                max: "dataMax",
            },
            yAxis: {
                scale: true,
                splitArea: {
                    show: true,
                },
            },
            dataZoom: [
                {
                    type: "inside",
                    start: 50,
                    end: 100,
                },
                {
                    show: true,
                    type: "slider",
                    top: "90%",
                    start: 50,
                    end: 100,
                },
            ],
            series: [
                {
                    name: timeLevel,
                    type: "candlestick",
                    data: data0.values,
                    itemStyle: {
                        color: upColor,
                        color0: downColor,
                        borderColor: upBorderColor,
                        borderColor0: downBorderColor,
                    },
                    markPoint: {
                        label: {
                            formatter: function (param) {
                                return param != null ? Math.round(param.value) + "" : "";
                            },
                        },
                        tooltip: {
                            formatter: function (param) {
                                return param.name + "<br>" + (param.data.coord || "");
                            },
                        },
                    },
                    markArea: {
                        data: [
                            ...markArea,
                        ],
                        label: {
                            show: false,
                        },
                    },
                    markPoint: {
                        data: markPointData,
                    },
                    markLine: {
                        data: markLineData,
                    },
                },
                {
                    name: "SMA",
                    type: "line",
                    data: calculateMA(10),
                    smooth: true,
                    symbol: 'none',
                    lineStyle: {
                        opacity: 0.5,
                    },
                },
                {
                    name: "EMA",
                    type: "line",
                    data: calculateEMA(100),
                    smooth: true,
                    symbol: 'none',
                    lineStyle: {
                        opacity: 0.5,
                    },
                },
                // {
                //     name: "UP",
                //     type: "line",
                //     data: B2upper,
                //     smooth: true,
                //     symbol: 'none',
                //     lineStyle: {
                //         opacity: 0.5,
                //     },
                // },
                // {
                //     name: "MA20",
                //     type: "line",
                //     symbol: 'none',
                //     data: B2basis,
                //     smooth: true,
                //     lineStyle: {
                //         opacity: 0.5,
                //     },
                // },
                // {
                //     name: "DN",
                //     type: "line",
                //     symbol: 'none',
                //     data: B2lower,
                //     smooth: true,
                //     lineStyle: {
                //         opacity: 0.5,
                //     },
                // },
                // {
                //     name: "EMASHORT",
                //     type: "line",
                //     symbol: 'none',
                //     data: calculateMA(3),
                //     smooth: true,
                //     lineStyle: {
                //         opacity: 0.5,
                //     },
                // },
                // {
                //     name: "EMALONG",
                //     type: "line",
                //     symbol: 'none',
                //     data: calculateMA(9),
                //     smooth: true,
                //     lineStyle: {
                //         opacity: 0.5,
                //     },
                // },
            ],
        };

        chart.setOption(optionK);
        chart2.setOption(option);
    </script>
</body>

</html>